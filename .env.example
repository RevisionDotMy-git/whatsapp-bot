# Port for Fastify backend server
PORT=4000

# PostgreSQL Database Connection URL (Prisma compatible)
DATABASE_URL="postgresql://username:password@localhost:5432/workshop_bot?schema=public"

# LearnDash WordPress API Credentials
LEARNDASH_BASE_URL="https://your-wordpress-site.com"
LEARNDASH_JWT_USERNAME="your_api_username"
LEARNDASH_JWT_PASSWORD="your_api_password"

# Gemini LLM API Key (For essay grading and correction)
GEMINI_API_KEY="your_gemini_api_key_here"

# WhatsApp Bot Phone Number (Used to distinguish self/bot sender in Baileys)
BOT_PHONE_NUMBER="60123456789"
